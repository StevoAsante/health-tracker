# ============================================================
# .env.example — Template for Environment Variables
# ============================================================
# This file IS committed to Git — it shows other team members
# what variables they need to set, without exposing real values.
#
# SETUP: Copy this file to .env and fill in your own values
# ============================================================

DB_HOST=localhost # or your DB host if not local, should be emailed to you by UEA
DB_PORT=5432
DB_NAME=whatever_your_uea_username_is # usually the same as your DB_USER
DB_USER=whatever_your_uea_username_is # without "@uea.ac.uk"
DB_PASSWORD=password123 # replace with your actual DB password (emailed to us by UEA)
SESSION_SECRET=this_should_be_a_long_random_string # generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PORT=3000
